def build_unity_shot_data(
    predicted_label: str,
    estimated_ball_speed_mph: float,
    club_head_speed_mph: float,
    club: str
):
    """
    Convert the app's predicted shot label + club + speeds
    into Unity-friendly shot parameters.
    """

    base_launch = CLUB_LAUNCH_ANGLES.get(club, 18.0)

    shot_data = {
        "shotType": predicted_label,
        "club": club,
        "clubHeadSpeedMph": round(float(club_head_speed_mph), 2),
        "ballSpeedMph": round(float(estimated_ball_speed_mph), 2),
        "launchAngleDegrees": base_launch,
        "sideAngleDegrees": 0.0,
        "curveSpeedPerSecond": 0.0,
    }

    if predicted_label == "Strait":
        shot_data["sideAngleDegrees"] = 0.0
        shot_data["curveSpeedPerSecond"] = 0.0

    elif predicted_label == "Draw":
        shot_data["sideAngleDegrees"] = 6
        shot_data["curveSpeedPerSecond"] = -4

    elif predicted_label == "Fade":
        shot_data["sideAngleDegrees"] = -6
        shot_data["curveSpeedPerSecond"] = 4

    elif predicted_label == "ToeStrait":
        shot_data["launchAngleDegrees"] = base_launch - 1.0
        shot_data["sideAngleDegrees"] = 1.0
        shot_data["curveSpeedPerSecond"] = 2.0

    elif predicted_label == "ToeDraw":
        shot_data["launchAngleDegrees"] = base_launch - 1.0
        shot_data["sideAngleDegrees"] = 6
        shot_data["curveSpeedPerSecond"] = -4

    elif predicted_label == "ToeFade":
        shot_data["launchAngleDegrees"] = base_launch - 1.0
        shot_data["sideAngleDegrees"] = -4
        shot_data["curveSpeedPerSecond"] = 6

    elif predicted_label == "HeelStrait":
        shot_data["launchAngleDegrees"] = base_launch - 1.0
        shot_data["sideAngleDegrees"] = 0
        shot_data["curveSpeedPerSecond"] = 0

    elif predicted_label == "HeelDraw":
        shot_data["launchAngleDegrees"] = base_launch - 1.0
        shot_data["sideAngleDegrees"] = 6
        shot_data["curveSpeedPerSecond"] = -4

    elif predicted_label == "HeelFade":
        shot_data["launchAngleDegrees"] = base_launch - 1.0
        shot_data["sideAngleDegrees"] = -6
        shot_data["curveSpeedPerSecond"] = 4

    elif predicted_label == "ChunkStrait":
        shot_data["launchAngleDegrees"] = base_launch - 2
        shot_data["sideAngleDegrees"] = 0.0
        shot_data["curveSpeedPerSecond"] = 0.0

    elif predicted_label == "ChunkDraw":
        shot_data["launchAngleDegrees"] = base_launch - 2
        shot_data["sideAngleDegrees"] = 6
        shot_data["curveSpeedPerSecond"] = -4.0

    elif predicted_label == "ChunkFade":
        shot_data["launchAngleDegrees"] = base_launch - 2
        shot_data["sideAngleDegrees"] = -6
        shot_data["curveSpeedPerSecond"] = 4.0

    elif predicted_label == "ChunkToeStrait":
        shot_data["launchAngleDegrees"] = base_launch - 2
        shot_data["sideAngleDegrees"] = 0
        shot_data["curveSpeedPerSecond"] = 0

    elif predicted_label == "ChunkToeDraw":
        shot_data["launchAngleDegrees"] = base_launch - 2
        shot_data["sideAngleDegrees"] = 6
        shot_data["curveSpeedPerSecond"] = -4.0

    elif predicted_label == "ChunkToeFade":
        shot_data["launchAngleDegrees"] = base_launch - 2
        shot_data["sideAngleDegrees"] = -6
        shot_data["curveSpeedPerSecond"] = 4

    elif predicted_label == "ChunkHeelStrait":
        shot_data["launchAngleDegrees"] = base_launch - 2
        shot_data["sideAngleDegrees"] = 0
        shot_data["curveSpeedPerSecond"] = 0

    elif predicted_label == "ChunkHeelDraw":
        shot_data["launchAngleDegrees"] = base_launch - 2
        shot_data["sideAngleDegrees"] = 6
        shot_data["curveSpeedPerSecond"] = -4

    elif predicted_label == "ChunkHeelFade":
        shot_data["launchAngleDegrees"] = base_launch - 2
        shot_data["sideAngleDegrees"] = -6
        shot_data["curveSpeedPerSecond"] = 4.0

    elif predicted_label == "Topped":
        shot_data["launchAngleDegrees"] = max(1.0, base_launch - 18.0)
        shot_data["sideAngleDegrees"] = 0.0
        shot_data["curveSpeedPerSecond"] = 0.0

    shot_data["launchAngleDegrees"] = round(
        max(1.0, min(shot_data["launchAngleDegrees"], 45.0)), 2
    )

    return shot_data

