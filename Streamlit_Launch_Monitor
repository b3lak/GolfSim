def classify_uploaded_image(uploaded_file):
    test_img = preprocess_uploaded_file(uploaded_file)
    scores = []

    reference_library = get_labeled_reference_library()

    if not reference_library:
        raise ValueError(
            f"No labeled reference images found.\n"
            f"Put images into folders like:\n{LABELED_DIR}\\Draw\\\n{LABELED_DIR}\\Fade\\"
        )

    for label, image_path in reference_library:
        ref_img = preprocess_from_path(image_path)
        score = ssim(test_img, ref_img)
        scores.append((label, score, image_path))

    scores.sort(key=lambda x: x[1], reverse=True)
    return scores[0], scores


def estimate_smash_and_ball_speed(best_label: str, club: str, club_speed_mph: float):
    if club not in BASE_SMASH:
        raise ValueError(f"Unknown club: {club}")

    if best_label not in STRIKE_MODIFIERS:
        raise ValueError(f"Unknown strike label: {best_label}")

    baseline_smash = BASE_SMASH[club]
    strike_modifier = STRIKE_MODIFIERS[best_label]
    estimated_smash = baseline_smash * strike_modifier
    estimated_ball_speed = club_speed_mph * estimated_smash

    return baseline_smash, strike_modifier, estimated_smash, estimated_ball_speed


def save_uploaded_file(uploaded_file) -> str:
    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    safe_name = uploaded_file.name.replace(" ", "_")
    filename = f"{timestamp}_{safe_name}"
    save_path = os.path.join(UPLOADS_DIR, filename)

    with open(save_path, "wb") as f:
        f.write(uploaded_file.getbuffer())

    return save_path


def copy_to_labeled_folder(image_path: str, user_label: str):
    if not user_label:
        return

    target_dir = os.path.join(LABELED_DIR, user_label)
    os.makedirs(target_dir, exist_ok=True)

    filename = os.path.basename(image_path)
    target_path = os.path.join(target_dir, filename)
    shutil.copy2(image_path, target_path)


