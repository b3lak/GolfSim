using UnityEngine;

public class BallGroundTracker : MonoBehaviour
{
    public BallLauncher launcher;

    private void OnCollisionEnter(Collision collision)
    {
        if (launcher == null)
            return;

        if (collision.gameObject.CompareTag("Ground") || collision.gameObject.GetComponent<Terrain>() != null)
        {
            launcher.NotifyGroundImpact(transform.position);
        }
    }
}
