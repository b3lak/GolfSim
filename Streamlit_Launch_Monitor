def preprocess_cv_image(img_bgr: np.ndarray) -> np.ndarray:
    gray = cv2.cvtColor(img_bgr, cv2.COLOR_BGR2GRAY)
    gray = cv2.GaussianBlur(gray, BLUR_KERNEL, 0)
    gray = cv2.resize(gray, IMG_SIZE)
    return gray


def preprocess_from_path(image_path: str) -> np.ndarray:
    img = cv2.imread(image_path)
    if img is None:
        raise FileNotFoundError(f"Could not read image: {image_path}")
    return preprocess_cv_image(img)


def preprocess_uploaded_file(uploaded_file) -> np.ndarray:
    pil_img = Image.open(uploaded_file).convert("RGB")
    img_rgb = np.array(pil_img)
    img_bgr = cv2.cvtColor(img_rgb, cv2.COLOR_RGB2BGR)
    return preprocess_cv_image(img_bgr)


def get_labeled_reference_library():
    library = []

    if not os.path.exists(LABELED_DIR):
        return library

    for label in os.listdir(LABELED_DIR):
        label_dir = os.path.join(LABELED_DIR, label)

        if not os.path.isdir(label_dir):
            continue

        for filename in os.listdir(label_dir):
            if filename.lower().endswith((".jpg", ".jpeg", ".png", ".webp")):
                image_path = os.path.join(label_dir, filename)
                library.append((label, image_path))

    return library

